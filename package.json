{
  "name": "simplecrm",
  "version": "0.1.7",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "packages/core",
    "packages/server",
    "packages/desktop"
  ],
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build:packages": "tsc -b packages/core packages/server packages/desktop",
    "build:web": "tsc && vite build",
    "build:electron:main": "tsc -p tsconfig.electron.json",
    "build": "npm run build:packages && npm run build:web && npm run build:electron:main",
    "build:watch": "tsc && vite build --watch",
    "build:electron": "vite build && tsc -p tsconfig.electron.json",
    "build:electron:watch": "vite build --watch",
    "electron:compile": "tsc -p tsconfig.electron.json",
    "electron:compile:watch": "tsc -p tsconfig.electron.json --watch",
    "electron:dev:main": "nodemon --watch dist-electron --delay 2500ms --exec \"cross-env NODE_ENV=development electron dist-electron/main.js\" --ext js",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit && tsc -b packages/core packages/server packages/desktop",
    "svelte-lab:dev": "npm run dev --prefix packages/svelte-lab",
    "svelte-lab:build": "npm run build --prefix packages/svelte-lab",
    "electron:dev": "npm run electron:compile && concurrently \"cross-env NODE_ENV=development vite build --watch\" \"npm run electron:compile:watch\" \"npm run electron:dev:main\" \"cross-env NODE_ENV=development VITE_DEV_CACHE=1 vite --port 5173 --host --clearScreen false\" --names \"ElectronBundle,ElectronTS,ElectronMain,Vite\" --kill-others-on-exit",
    "electron:build": "npm run build && cross-env DEBUG=electron-builder* NODE_ENV=production electron-builder",
    "electron:publish": "npm run build && cross-env DEBUG=electron-builder* NODE_ENV=production electron-builder --publish always",
    "electron:start": "cross-env NODE_ENV=production electron dist-electron/main.js",
    "postinstall": "node node_modules/electron/install.js && node scripts/patch-better-sqlite3.js && electron-rebuild",
    "seed-db": "cross-env NODE_ENV=development ts-node --project scripts/tsconfig.json scripts/seed-database.ts",
    "seed-db:test": "cross-env NODE_ENV=development ts-node --project scripts/tsconfig.json scripts/seed-database.ts --customers 100 --products 50 --yes",
    "cleanup-db": "cross-env NODE_ENV=development ts-node --project scripts/tsconfig.json scripts/cleanup-database.ts",
    "cleanup-db:dry": "cross-env NODE_ENV=development ts-node --project scripts/tsconfig.json scripts/cleanup-database.ts --dry-run",
    "test:performance": "node scripts/performance-test-deals.js",
    "test:performance:simple": "node scripts/performance-test-deals-simple.js",
    "doctor:server": "node packages/server/dist/cli/doctor.js",
    "migrate:standalone-to-server": "node packages/desktop/dist/cli/migrate-to-server.js",
    "migrate:sqlite": "node packages/server/dist/cli/migrate-from-sqlite.js",
    "migrate:server": "node packages/server/dist/cli/migrate.js",
    "test:server-rls": "node packages/server/dist/cli/rls-check.js",
    "check:dangerous-defaults": "node scripts/check-dangerous-defaults.js",
    "electron:dev:debug": "npm run build:electron && cross-env NODE_ENV=development electron dist-electron/main.js",
    "electron:test:devtools": "npm run build && cross-env NODE_ENV=production electron dist-electron/main.js",
    "test": "jest",
    "test:unit": "jest --selectProjects unit",
    "test:integration": "jest --selectProjects integration",
    "test:e2e": "pnpm run build && playwright test -c tests/e2e/playwright.electron.config.ts",
    "test:all": "pnpm test:coverage && pnpm test:e2e",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --selectProjects unit integration",
    "test:mail": "jest --config=jest.mail.config.cjs --coverageThreshold={}",
    "test:mail:coverage": "jest --config jest.mail.config.cjs",
    "test:mail:coverage:update-baseline": "npm run test:mail:coverage && node scripts/check-mail-coverage-ratchet.mjs --update-baseline",
    "test:server:coverage": "jest --config jest.server.config.cjs",
    "test:server:coverage:update-baseline": "npm run test:server:coverage && node scripts/check-server-coverage-ratchet.mjs --update-baseline",
    "test:ui:coverage": "jest --config jest.ui.config.cjs",
    "test:ui:coverage:update-baseline": "npm run test:ui:coverage && node scripts/check-ui-coverage-ratchet.mjs --update-baseline",
    "test:ui:coverage:check": "npm run test:ui:coverage && node scripts/check-ui-coverage-ratchet.mjs",
    "test:server-edition": "jest --runTestsByPath tests/unit/server-edition-foundation.test.ts tests/integration/server-edition-foundation.test.ts --runInBand",
    "test:electron": "jest --testMatch='**/__tests__/electron/**/*.test.ts'",
    "test:frontend": "jest --testMatch='**/__tests__/frontend/**/*.test.tsx'"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-accordion": "^1.2.13",
    "@radix-ui/react-alert-dialog": "^1.1.16",
    "@radix-ui/react-aspect-ratio": "^1.1.9",
    "@radix-ui/react-avatar": "^1.1.12",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-collapsible": "^1.1.13",
    "@radix-ui/react-context-menu": "^2.3.0",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-hover-card": "^1.1.16",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-menubar": "^1.1.17",
    "@radix-ui/react-navigation-menu": "^1.2.15",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-progress": "^1.1.9",
    "@radix-ui/react-radio-group": "^1.4.0",
    "@radix-ui/react-scroll-area": "^1.2.11",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slider": "^1.4.0",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-toast": "^1.2.16",
    "@radix-ui/react-toggle": "^1.1.11",
    "@radix-ui/react-toggle-group": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@simplecrm/core": "0.1.0",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-table": "^8.21.3",
    "@types/react-big-calendar": "^1.16.3",
    "@xyflow/react": "^12.11.0",
    "archiver": "^7.0.1",
    "better-sqlite3": "github:WiseLibs/better-sqlite3#v12.7.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "^4.4.0",
    "dompurify": "^3.4.8",
    "electron-log": "^5.4.4",
    "electron-serve": "^3.0.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "electron-window-state": "^5.0.3",
    "embla-carousel-react": "8.6.0",
    "google-auth-library": "^10.7.0",
    "imapflow": "^1.3.6",
    "input-otp": "1.4.2",
    "keytar": "^7.9.0",
    "lucide-react": "^1.17.0",
    "mailauth": "^4.13.3",
    "mailparser": "^3.9.9",
    "monaco-editor": "^0.55.1",
    "mssql": "^12.5.5",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "node-pop3": "^0.11.0",
    "nodemailer": "^8.0.10",
    "openpgp": "^6.3.1",
    "quill": "^2.0.3",
    "react": "^19.2.7",
    "react-big-calendar": "^1.20.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.77.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "^3.8.1",
    "safe-regex": "^2.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "yauzl": "^3.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/mssql": "^12.0.0",
    "@types/node": "^24.10.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/yauzl": "^3.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.0",
    "eslint": "^10.4.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.4.1",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.60.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vite-plugin-electron": "^1.0.4",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vite-tsconfig-paths": "^6.1.1",
    "wait-on": "^9.0.10"
  },
  "pnpm": {
    "overrides": {
      "app-builder-bin": "4.2.0",
      "node-abi": "^4.31.0",
      "jest-mock": "30.4.1",
      "jest-runtime": "30.4.2",
      "jest-circus": "30.4.0"
    },
    "onlyBuiltDependencies": [
      "electron",
      "better-sqlite3",
      "esbuild",
      "keytar",
      "mssql",
      "@parcel/watcher"
    ]
  },
  "build": {
    "appId": "com.zondiac.simplecrm",
    "productName": "SimpleCRM",
    "files": [
      "dist/",
      "dist-electron/",
      "dist-electron/preload.js",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist-build"
    },
    "publish": [
      {
        "provider": "github"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "src/app/simplecrmlogo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "assets/icons/512x512.png"
    },
    "linux": {
      "icon": "icons",
      "category": "Office"
    }
  }
}
