# SimpleCRM server Docker environment.
# Copy to docker/.env and replace every CHANGE_ME value before starting the stack.

VERSION=dev

# Public URL used for links, redirects, invite mails, and the Caddy virtual host.
PUBLIC_DOMAIN=localhost
PUBLIC_BASE_URL=http://localhost
# Optional comma-separated browser origins for server-client HTTP transport.
# PUBLIC_BASE_URL is allowed automatically. Add separate app origins only when needed.
CORS_ALLOWED_ORIGINS=
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# Generate strong values with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# MASTER_KEY must decode to exactly 32 bytes.
# ACCESS_TOKEN_SECRET must decode to at least 32 bytes.
# PG_ADMIN_PASSWORD is used only by PostgreSQL bootstrap and maintenance profiles.
# PG_PASSWORD is the non-superuser application role password.
PG_ADMIN_PASSWORD=CHANGE_ME_postgres_admin_password
PG_PASSWORD=CHANGE_ME_postgres_app_password
MASTER_KEY=CHANGE_ME_base64_32_bytes
ACCESS_TOKEN_SECRET=CHANGE_ME_base64_32_bytes

# Attachments and audit archives are stored in Docker volumes by default.
ATTACHMENTS_DIR=/app/data/attachments
AUDIT_ARCHIVE_DIR=/app/data/audit-archive

# Background worker. REQUIRED for a productive single-node deployment: while
# disabled, IMAP/POP3 mail sync, scheduled send, vacation auto-reply, AI reply
# suggestions, workflow execution and webhook delivery DO NOT run — the API
# stays read/compose-capable, but no mail is fetched and no background work is
# processed. Set JOB_WORKER_ENABLED=true to run the in-process worker (it
# installs its own graphile_worker schema on start and polls the legacy
# job_queue table for workflow side-effects such as email.forward_copy).
# Leave at false only for a read-only/API-smoke setup or when running a
# dedicated worker process.
JOB_WORKER_ENABLED=false
# Concurrent IMAP/POP3 account syncs the worker keeps in flight (raise per fleet size).
JOB_WORKER_MAIL_ACCOUNT_COUNT=0
JOB_WORKER_AI_CONCURRENCY=5
JOB_WORKER_MIGRATE_ON_START=false
JOB_WEBHOOK_ALLOWLIST=

# Central server log: every warning/error is captured into this JSONL file (on
# the server_logs volume, so it survives restarts/rebuilds) and exposed read-only
# under Settings -> Diagnose -> Server-Logs. LOG_LEVEL controls stdout verbosity.
SERVER_LOG_FILE=/app/data/logs/server-log.jsonl
LOG_LEVEL=info

# Optional invite mail delivery. Leave empty to return manual invite links.
AUTH_INVITE_FROM=
AUTH_INVITE_SMTP_HOST=
AUTH_INVITE_SMTP_PORT=587
AUTH_INVITE_SMTP_TLS=true
AUTH_INVITE_SMTP_USER=
AUTH_INVITE_SMTP_PASSWORD=
AUTH_INVITE_SMTP_TIMEOUT_MS=90000

# Optional Cloudflare Turnstile for public login CAPTCHA (set both keys to enable provider).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Backup scheduler / doctor.
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RUN_ON_START=true
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=12
DOCTOR_REQUIRE_BACKUP=false

# Restore helpers. Leave empty to auto-detect the latest matching backup set.
RESTORE_DUMP_PATH=
RESTORE_ATTACHMENTS_PATH=
RESTORE_AUDIT_ARCHIVE_PATH=
RESTORE_CADDY_HEALTH_URL=
RESTORE_DRILL_DB_NAME=
RESTORE_DRILL_DUMP_PATH=
RESTORE_DRILL_ATTACHMENTS_PATH=
RESTORE_DRILL_AUDIT_ARCHIVE_PATH=

# Optional profile: MinIO for future S3-compatible attachment storage drills.
# Defaults bind to localhost so the consoles are not exposed publicly.
MINIO_ROOT_USER=simplecrm
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_root_password
MINIO_API_BIND=127.0.0.1
MINIO_API_PORT=9000
MINIO_CONSOLE_BIND=127.0.0.1
MINIO_CONSOLE_PORT=9001

# Optional profile: Uptime Kuma monitor.
UPTIME_KUMA_BIND=127.0.0.1
UPTIME_KUMA_PORT=3001

# Optional profile: pgAdmin for setup/debug only. Never expose this publicly.
PGADMIN_DEFAULT_EMAIL=admin@example.local
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_pgadmin_password
PGADMIN_BIND=127.0.0.1
PGADMIN_PORT=5050
