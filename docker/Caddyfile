{$PUBLIC_DOMAIN:localhost} {
	encode gzip zstd

	# API, health probes, OpenAPI and the SSE/WebSocket event stream (/api/v1/events)
	# go to the Fastify backend. Spoofable identity headers are stripped here.
	@backend path /api/* /health /health/* /openapi.json
	handle @backend {
		reverse_proxy api:3000 {
			header_up -x-simplecrm-user-id
			header_up -x-simplecrm-workspace-id
			header_up -x-simplecrm-role
		}
	}

	# Single-page app: serve built assets, fall back to index.html for client routes.
	handle {
		root * /srv/dist
		try_files {path} /index.html
		file_server
	}

	log {
		output file /var/log/access.log
		format json
	}
}
