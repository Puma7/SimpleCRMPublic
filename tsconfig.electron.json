{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "outDir": "./dist-electron",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "Node16",
    "sourceMap": true,
    "paths": {
      "@shared/*": [
        "./shared/*"
      ]
    },
    "isolatedModules": true
  },
  "include": [
    "electron/**/*.ts",
    "electron/**/*.d.ts",
    "shared/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "electron/preload.ts"
  ]
}
